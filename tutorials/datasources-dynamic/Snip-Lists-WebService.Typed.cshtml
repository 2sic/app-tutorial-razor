@inherits Custom.Hybrid.RazorTyped
@using ToSic.Razor.Blade
@using System.Linq
@using AppCode.DataSources
@*!
Tut.Tabs=datasource:DataFromWebService,file:/AppCode/DataSources/DataFromWebServiceJsonModels.cs
!*@
@{
  // Create the Dynamic DataSource DataFromWebService
  var weather = Kit.Data.GetSource<DataFromWebService>();
  var item = AsItem(weather);
}
<h3>Data in the DataSource (@weather.List.Count())</h3>
<ul>
  <li>Current Temperature: @item.Float("Temperature")</li>
  <li>WindSpeed: @item.Float("WindSpeed")</li>
  <li>WindDirection: @item.String("WindDirection")</li>
</ul>
