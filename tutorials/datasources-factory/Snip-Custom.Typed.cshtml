@inherits Custom.Hybrid.RazorTyped
@using ToSic.Razor.Blade
@using System.Linq
@using AppCode.DataSources
@{
  var dsWithOptions = Kit.Data.GetSource<FactoryOptions>();
}
<h3>Data in the DataSource (@dsWithOptions.List.Count())</h3>
<ul>
  @foreach (var item in AsItems(dsWithOptions)) {
    <li>
      <strong>@item.Title</strong> (id: @item.Id, type: @item.Type.Name)
    </li>
  }
</ul>